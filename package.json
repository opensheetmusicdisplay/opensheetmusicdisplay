{
  "name": "@my-groove/opensheetmusicdisplay",
  "version": "1.9.0-mg3",
  "description": "An open source JavaScript engine for displaying MusicXML based on VexFlow.",
  "main": "build/dist/src/index.js",
  "types": "build/dist/src/index.d.ts",
  "type": "module",
  "scripts": {
    "docs": "typedoc --out ./build/docs --name OpenSheetMusicDisplay ./src",
    "eslint": "eslint -c .eslintrc.js --ext .ts .",
    "lint": "npm run eslint",
    "test": "karma start --single-run --no-auto-watch",
    "test:watch": "karma start --no-single-run --auto-watch --browsers ChromeNoSecurity",
    "prepare": "npm-run-all husky build",
    "build": "tsc",
    "husky": "husky",
    "generatePNG": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 1 allSmall --osmdtesting",
    "generateSVG": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export/svg svg 0 0 1 allSmall --osmdtesting",
    "generateExplore:mygroove": "node ./test/Util/generateImages_browserless.mjs ../../build ./export/input/explore ./export/output/explore png 0 0 3",
    "generateExplore:svg:mygroove": "node ./test/Util/generateImages_browserless.mjs ../../build ./export/input/explore ./export/output/explore/svg svg 0 0 1 100000",
    "generateGroove:mygroove": "node ./test/Util/generateImages_browserless.mjs ../../build ./export/input/groove ./export/output/groove svg 0 0 1 100000",
    "generatePNG:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 1 allSmall --debugosmdtesting",
    "generatePNG:single": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 1 ^Beethoven",
    "generatePNG:legacyslow": "node ./test/Util/generateDiffImagesPuppeteerLocalhost.js ./test/data ./export png 0 0 1 all",
    "generatePNG:paged": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 210 297 1 allSmall",
    "generatePNG:paged:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 210 297 1 all --debug 5000",
    "generatePNG:paged:single": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 1 ^Beethoven",
    "generate:current": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 1 allSmall --osmdtesting",
    "generate:current:batch": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 1 allSmall --osmdtesting 0 --batch",
    "generate:current:webgl": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 1 allSmall --osmdtesting 0 --webgl",
    "generate:current:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 1 allSmall --debugosmdtesting",
    "generate:current:singletest": "node test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 1 ^Beethoven --osmdtestingsingle",
    "generate:blessed": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/blessed png 0 0 1 allSmall --osmdtesting",
    "test:visual": "bash ./test/Util/visual_regression.sh ./visual_regression",
    "test:visual:singletest": "sh ./test/Util/visual_regression.sh ./visual_regression Beethoven",
    "fix-memory-limit": "cross-env NODE_OPTIONS=--max_old_space_size=4096"
  },
  "pre-commit": [
    "lint"
  ],
  "files": [
    "build/dist/src",
    "build/opensheetmusicdisplay.min.js",
    "build/generateImages_browserless.mjs",
    "src/VexFlowPatch",
    "scripts/apply-vexflow-patches.cjs",
    "scripts/restore-vexflow.cjs",
    "scripts/test-patches.cjs",
    "AUTHORS",
    "CHANGELOG.md",
    "README.md",
    "INSTALLATION.md",
    "external",
    "tsconfig.json"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/my-groove/osmd"
  },
  "keywords": [
    "sheet",
    "music",
    "vexflow",
    "musicxml"
  ],
  "author": "PhonicScore",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/opensheetmusicdisplay/opensheetmusicdisplay/issues"
  },
  "homepage": "https://opensheetmusicdisplay.org",
  "dependencies": {
    "@types/vexflow": "^1.2.38",
    "cross-blob": "^3.0.0",
    "jsdom": "^19.0.0",
    "jszip": "3.10.1",
    "loglevel": "^1.8.0",
    "minimatch": "^10.0.3",
    "typescript-collections": "^1.3.3",
    "vexflow": "github:my-groove/vexflow#abf6026693ad1a43dc7ae5df5c0d773dcc9e6b02"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin-ts": "^3.1.0",
    "@types/node": "^24.6.2",
    "@typescript-eslint/eslint-plugin": "^8.0",
    "@typescript-eslint/parser": "^8.0",
    "canvas": "^3.1.0",
    "chai": "^4.3.4",
    "copy-webpack-plugin": "^11.0.0",
    "copyfiles": "^2.4.1",
    "cross-env": "^7.0.3",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsdoc": "^46.4.5",
    "eslint-plugin-no-null": "^1.0.2",
    "eslint-plugin-node": "^11.1.0",
    "html-webpack-plugin": "^5.5.0",
    "husky": "^9.1.7",
    "jquery": "^3.6.0",
    "jsdom": "^26.0.0",
    "jspdf": "^3.0.1",
    "karma": "^6.4.2",
    "karma-base64-to-js-preprocessor": "^0.1.0",
    "karma-chai": "^0.1.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-firefox-launcher": "^2.1.2",
    "karma-mocha": "^2.0.1",
    "karma-mocha-reporter": "^2.2.5",
    "karma-webpack": "^5.0.1",
    "karma-xml2js-preprocessor": "^0.1.0",
    "mocha": "^11.1.0",
    "ncp": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "svg2pdf.js": "^2.5.0",
    "ts-loader": "^9.2.6",
    "typedoc": "^0.28.1",
    "typescript": "5.8.2",
    "webpack": "^5.64.4",
    "webpack-cli": "^4.9.1",
    "webpack-dev-server": "^4.7.0",
    "webpack-merge": "^5.8.0",
    "webpack-visualizer-plugin2": "^1.0.0"
  },
  "optionalDependencies": {
    "gl": "^8.1.6"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}