{
  "name": "opensheetmusicdisplay",
  "version": "1.9.9",
  "description": "An open source JavaScript engine for displaying MusicXML based on VexFlow.",
  "main": "build/opensheetmusicdisplay.min.js",
  "types": "build/dist/src/index.d.ts",
  "scripts": {
    "docs": "typedoc --out ./build/docs --name OpenSheetMusicDisplay ./src",
    "preeslint": "node -e \"if(parseInt(process.versions.node,10)<20){console.error('ESLint 10 requires Node >=20.19, 22.13, or 24+ (you have '+process.versions.node+'). Please upgrade Node.');process.exit(1)}\"",
    "eslint": "eslint .",
    "lint": "npm run eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:all": "vitest run && vitest run --config vitest.browser.config.ts",
    "prebuild": "",
    "prepare": "npm-run-all husky build",
    "build": "npm-run-all lint build:webpack",
    "build:webpack": "webpack --progress --config webpack.prod.js",
    "build:webpack-dev": "webpack --progress --config webpack.dev.js",
    "build:webpack-sourcemap": "webpack --progress --config webpack.sourcemap.js",
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s",
    "husky": "husky",
    "start": "webpack-dev-server --progress --config webpack.dev.js",
    "start:local": "webpack-dev-server --progress --config webpack.local.js",
    "generatePNG": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 allSmall --osmdtesting",
    "generateSVG": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export/svg svg 0 0 allSmall --osmdtesting",
    "generatePNG:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 allSmall --debugosmdtesting",
    "generatePNG:single": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 ^Beethoven",
    "generatePNG:legacyslow": "node ./test/Util/generateDiffImagesPuppeteerLocalhost.js ./test/data ./export png 0 0 all",
    "generatePNG:paged": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 210 297 allSmall",
    "generatePNG:paged:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 210 297 all --debug 5000",
    "generatePNG:paged:single": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./export png 0 0 ^Beethoven",
    "generate:current": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 allSmall --osmdtesting --svg",
    "generate:current:batch": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 allSmall --osmdtesting 0 --batch",
    "generate:current:webgl": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 allSmall --osmdtesting 0 --webgl",
    "generate:current:debug": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 allSmall --debugosmdtesting",
    "generate:current:singletest": "node test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 ^Beethoven --osmdtestingsingle",
    "generate:current:skyline": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/current png 0 0 allSmall --osmdtesting --svg --show-skyline",
    "generate:blessed": "node ./test/Util/generateImages_browserless.mjs ../../build ./test/data ./visual_regression/blessed png 0 0 allSmall --osmdtesting",
    "test:visual": "bash ./test/Util/visual_regression.sh ./visual_regression",
    "test:visual:build": "npm-run-all build:webpack generate:current test:visual",
    "test:visual:build:batch": "npm-run-all build:webpack generate:current:batch test:visual",
    "test:visual:build:webgl": "npm-run-all build:webpack generate:current:webgl test:visual",
    "test:visual:singletest": "sh ./test/Util/visual_regression.sh ./visual_regression Beethoven",
    "test:svg-layout": "node test/Util/validateSvgLayout.cjs visual_regression/current/"
  },
  "pre-commit": [
    "lint"
  ],
  "files": [
    "build/dist/src",
    "build/opensheetmusicdisplay.min.js",
    "AUTHORS",
    "CHANGELOG.md",
    "README.md",
    "external"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/opensheetmusicdisplay/opensheetmusicdisplay"
  },
  "keywords": [
    "sheet",
    "music",
    "vexflow",
    "musicxml"
  ],
  "author": "PhonicScore",
  "license": "BSD-3-Clause",
  "bugs": {
    "url": "https://github.com/opensheetmusicdisplay/opensheetmusicdisplay/issues"
  },
  "homepage": "https://opensheetmusicdisplay.org",
  "dependencies": {
    "jszip": "3.10.1",
    "loglevel": "^1.8.0",
    "typescript-collections": "^1.3.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/browser-chromium": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^24.12.2",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/coverage-v8": "^4.1.9",
    "canvas": "^3.2.3",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "globals": "^17.6.0",
    "html-webpack-plugin": "^5.6.7",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "jspdf": "^4.2.1",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "structured-clone-es": "^2.0.0",
    "svg2pdf.js": "^2.7.0",
    "ts-loader": "^9.5.7",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.9",
    "webpack": "^5.106.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3",
    "webpack-merge": "^5.8.0",
    "webpack-visualizer-plugin2": "^1.0.0"
  },
  "optionalDependencies": {
    "gl": "^9.0.0-rc.10"
  }
}
