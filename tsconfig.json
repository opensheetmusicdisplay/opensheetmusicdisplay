{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "module": "es2020",
    "moduleResolution": "bundler",
    "noUnusedLocals": true,
    "outDir": "build/dist",
    "declaration": true,
    "allowJs": true
  },
  "include": ["./.eslintrc.js", "./src/**/*.ts"],
  "exclude": [
    "node_modules/**/*",
    "dist",
    "demo",
    "build",
    "./src/VexFlowPatch/"
