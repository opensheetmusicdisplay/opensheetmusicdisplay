{
  "compilerOptions": {
    "target": "es2020",
    "esModuleInterop": true,
    "module": "commonjs",
    "noUnusedLocals": true,
    "outDir": "build/dist",
    "declaration": true,
    "sourceMap": true,
    "strict": false,
    "strictPropertyInitialization": false,
    "ignoreDeprecations": "6.0",
    "typeRoots": ["./node_modules/@types"],
    "types": ["mocha", "chai", "node"],
    "baseUrl": ".",
    "paths": {
      "vexflow": ["./external/vexflow/build/types/entry/vexflow.d.ts"]
    }
  },
  "include": ["./test/", "./src"],
  "exclude": [
    "node_modules",
    "dist",
    "demo",
    "build",
    "./src/VexFlowPatch/"
  ]
}
